# Copy this file to .env and fill in the values.

# --- MongoDB ---
# Connection string to your existing MongoDB instance
# Format: mongodb://username:password@host:port/database?authSource=database
# Example: mongodb://srapp:srapp-pass@localhost:27017/service_requests?authSource=service_requests
MONGO_URI=mongodb://username:password@host:port/service_requests

# --- API server ---
PORT=3000
CORS_ORIGIN=http://localhost:8080

# --- Azure Entra ID (Azure AD) ---
# Tenant GUID for your organization
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
# App registration (API) client ID
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Expected audience claim — typically api://<ENTRA_CLIENT_ID>
ENTRA_AUDIENCE=api://00000000-0000-0000-0000-000000000000

# --- Dev only ---
# Set to "true" to bypass Entra token validation for local development.
# NEVER set this in production.
DISABLE_AUTH=false
